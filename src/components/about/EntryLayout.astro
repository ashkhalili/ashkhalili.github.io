---
import BaseLayout from "@components/base/BaseLayout.astro";
import { markdownify } from "@lib/textConverter";
import { Image } from "astro:assets";
import type { AboutEntry } from "@/types";
import { render } from "astro:content";

interface Props {
  entry: AboutEntry;
}

const { entry } = Astro.props;
const { title, description, image, imageAlt } = entry.data;
const { Content } = await render(entry);
---

<BaseLayout title={title} description={description} image={image?.src}>
  <section class="section-sm">
    <div class="container">
      <!-- Profile Header -->
      <div class="row justify-center mb-6">
        <div
          class="bg-gradient-to-r from-slate-700 to-slate-900 rounded-xl px-8 py-8 md:col-10 lg:col-9 intersect:animate-fadeUp opacity-0 intersect-no-queue"
        >
          <div class="flex flex-col md:flex-row items-center md:items-end gap-6">
            {
              image && (
                <Image
                  class="rounded-xl w-36 h-36 object-cover shadow-lg border-2 border-white/20 shrink-0"
                  src={image}
                  alt={imageAlt}
                  width={400}
                  height={400}
                  loading="eager"
                />
              )
            }
            <div class="text-center md:text-left">
              <h1
                set:html={markdownify(title)}
                class="text-3xl font-bold tracking-tight mb-1 !text-white"
              />
              <p class="text-slate-300 text-base font-medium mb-1">
                Glaucoma Consultant — FRCOphth PhD
              </p>
              <p class="text-slate-400 text-sm">
                East Sussex Healthcare NHS Trust
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- CV Content -->
      <div class="row justify-center">
        <div
          class="glass rounded-xl p-8 md:col-10 lg:col-9 content intersect:animate-fadeUp opacity-0"
        >
          <Content />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
